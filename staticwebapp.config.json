{
  "routes": [
    {
      "route": "/app",
      "redirect": "https://textatruck.acidni.net"
    },
    {
      "route": "/signup",
      "redirect": "https://textatruck.acidni.net/signup"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*"]
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains"
  },
  "mimeTypes": {
    ".json": "text/json"
  }
}
