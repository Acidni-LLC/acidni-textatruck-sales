---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contact the Text-a-Truck team for sales, enterprise inquiries, or support.">
  <section class="py-24 bg-gradient-to-br from-orange-50 to-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl font-extrabold text-gray-900 mb-6">Get In Touch</h1>
      <p class="text-xl text-gray-500">
        Questions about enterprise plans, custom deployments, or general support?
        We're here to help.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
        <form
          action="https://apim-terprint-dev.azure-api.net/communications/api/contact"
          method="POST"
          class="space-y-6"
        >
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2" for="name">Full Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all text-gray-900"
              placeholder="Jane Smith"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2" for="email">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all text-gray-900"
              placeholder="jane@municipality.gov"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2" for="organization">Organization</label>
            <input
              type="text"
              id="organization"
              name="organization"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all text-gray-900"
              placeholder="City of Springfield Department of Public Works"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2" for="type">Inquiry Type</label>
            <select
              id="type"
              name="type"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all text-gray-900 bg-white"
            >
              <option value="enterprise">Enterprise / Municipal Plan</option>
              <option value="demo">Request a Demo</option>
              <option value="support">Technical Support</option>
              <option value="general">General Inquiry</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all text-gray-900 resize-none"
              placeholder="Tell us about your road hazard reporting needs..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-4 bg-orange-600 text-white font-bold rounded-xl hover:bg-orange-700 transition-all text-lg"
          >
            Send Message →
          </button>
        </form>
      </div>

      <div class="mt-12 grid grid-cols-2 gap-6 text-center">
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
          <div class="text-2xl mb-2">📧</div>
          <div class="font-semibold text-gray-900 mb-1">Email</div>
          <a href="mailto:support@acidni.net" class="text-orange-600 text-sm hover:underline">support@acidni.net</a>
        </div>
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
          <div class="text-2xl mb-2">🏢</div>
          <div class="font-semibold text-gray-900 mb-1">Company</div>
          <a href="https://www.acidni.com" class="text-orange-600 text-sm hover:underline">Acidni LLC</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
