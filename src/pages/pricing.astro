---
import Layout from '../layouts/Layout.astro';

const tiers = [
  {
    name: 'Free',
    price: '$0',
    period: '/month',
    description: 'Perfect for individual reporters and small communities.',
    features: [
      '1 intake channel (web form)',
      'Up to 50 reports/month',
      '7-day report history',
      'Basic incident dashboard',
      'Email notifications',
    ],
    cta: 'Get Started Free',
    href: 'https://textatruck.acidni.net/signup',
    highlight: false,
  },
  {
    name: 'Professional',
    price: '$49',
    period: '/month',
    description: 'For municipalities and fleet operators managing active roads.',
    features: [
      'All 3 intake channels (SMS, Voice, Web)',
      'Unlimited reports',
      '90-day history',
      'Live map dashboard',
      'Automated dispatch alerts',
      'Analytics & export',
      'API access',
    ],
    cta: 'Start Free Trial',
    href: 'https://textatruck.acidni.net/signup',
    highlight: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'For state DOTs, large municipalities, and multi-region deployments.',
    features: [
      'Everything in Professional',
      'Unlimited history',
      'Custom intake numbers',
      'GIS integration',
      'Dedicated support',
      'SLA guarantees',
      'On-premises option',
    ],
    cta: 'Contact Sales',
    href: '/contact',
    highlight: false,
  },
];
---

<Layout title="Pricing" description="Text-a-Truck pricing plans — free for individuals, $49/month for professionals, custom enterprise pricing.">
  <section class="py-24 bg-gradient-to-br from-orange-50 to-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl font-extrabold text-gray-900 mb-6">Simple, Transparent Pricing</h1>
      <p class="text-xl text-gray-500 max-w-2xl mx-auto">Start free. Scale as your community grows.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        {tiers.map(({ name, price, period, description, features, cta, href, highlight }) => (
          <div class={`rounded-2xl p-8 border-2 ${highlight ? 'border-orange-500 shadow-2xl shadow-orange-100 relative' : 'border-gray-100'}`}>
            {highlight && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-orange-600 text-white text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wide">
                Most Popular
              </div>
            )}
            <div class="mb-6">
              <h3 class="text-xl font-bold text-gray-900 mb-1">{name}</h3>
              <div class="flex items-end gap-1 mb-2">
                <span class="text-4xl font-extrabold text-gray-900">{price}</span>
                <span class="text-gray-400 text-sm pb-1">{period}</span>
              </div>
              <p class="text-sm text-gray-500">{description}</p>
            </div>
            <ul class="space-y-3 mb-8">
              {features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <span class="text-orange-500 mt-0.5">✓</span>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href={href}
              class={`block text-center py-3 px-6 rounded-xl font-semibold text-sm transition-all ${
                highlight
                  ? 'bg-orange-600 text-white hover:bg-orange-700'
                  : 'bg-gray-100 text-gray-800 hover:bg-gray-200'
              }`}
            >
              {cta}
            </a>
          </div>
        ))}
      </div>

      <div class="mt-16 text-center">
        <h3 class="text-xl font-bold text-gray-900 mb-4">Frequently Asked Pricing Questions</h3>
        <div class="max-w-2xl mx-auto space-y-4 text-left">
          {[
            { q: 'Is there a free trial for Professional?', a: 'Yes. Professional comes with a 14-day free trial, no credit card required.' },
            { q: 'Can I change plans at any time?', a: 'Absolutely. Upgrade or downgrade your plan at any time from your account dashboard.' },
            { q: 'What counts as a "report"?', a: 'Each unique hazard submission — whether via SMS, voice, or web form — counts as one report.' },
          ].map(({ q, a }) => (
            <details class="bg-gray-50 rounded-xl p-5 cursor-pointer">
              <summary class="font-semibold text-gray-900 list-none">{q}</summary>
              <p class="mt-3 text-gray-500 text-sm">{a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
