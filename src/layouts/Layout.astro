---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Text-a-Truck — Report road hazards instantly by text. Protect your community, save lives.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | Text-a-Truck</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | Text-a-Truck`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@acidni_llc" />

    <!-- Schema.org: SoftwareApplication -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Text-a-Truck",
        "applicationCategory": "PublicSafetyApplication",
        "operatingSystem": "Web, iOS, Android",
        "description": "Text-a-Truck is a multi-channel road hazard reporting platform. Drivers text, call, or submit online to report unsafe conditions — instantly routed to the right responders.",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "author": {
          "@type": "Organization",
          "name": "Acidni LLC",
          "url": "https://www.acidni.com"
        }
      }
    </script>

    <!-- Schema.org: Organization -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Acidni LLC",
        "url": "https://www.acidni.com",
        "sameAs": [
          "https://github.com/Acidni-LLC"
        ]
      }
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <!-- Nav -->
    <nav class="fixed top-0 inset-x-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 font-bold text-xl text-orange-600">
          🚛 Text-a-Truck
        </a>
        <div class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-600">
          <a href="/features" class="hover:text-gray-900 transition-colors">Features</a>
          <a href="/pricing" class="hover:text-gray-900 transition-colors">Pricing</a>
          <a href="/how-it-works" class="hover:text-gray-900 transition-colors">How It Works</a>
          <a href="/contact" class="hover:text-gray-900 transition-colors">Contact</a>
        </div>
        <div class="flex items-center gap-3">
          <a
            href="https://textatruck.acidni.net"
            class="hidden sm:inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
          >
            Log In
          </a>
          <a
            href="https://textatruck.acidni.net/signup"
            class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-orange-600 rounded-lg hover:bg-orange-700 transition-colors"
          >
            Get Started Free
          </a>
        </div>
      </div>
    </nav>

    <!-- Page Content -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-12 mt-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
          <div class="col-span-2 md:col-span-1">
            <div class="text-white font-bold text-lg mb-3">🚛 Text-a-Truck</div>
            <p class="text-sm leading-relaxed">Road hazard reporting for the modern age. Protect communities, one text at a time.</p>
          </div>
          <div>
            <h4 class="text-white font-semibold text-sm mb-3 uppercase tracking-wider">Product</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/features" class="hover:text-white transition-colors">Features</a></li>
              <li><a href="/pricing" class="hover:text-white transition-colors">Pricing</a></li>
              <li><a href="/how-it-works" class="hover:text-white transition-colors">How It Works</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold text-sm mb-3 uppercase tracking-wider">Company</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
              <li><a href="https://www.acidni.com" class="hover:text-white transition-colors">Acidni LLC</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-semibold text-sm mb-3 uppercase tracking-wider">Platform</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="https://textatruck.acidni.net" class="hover:text-white transition-colors">App Portal</a></li>
              <li><a href="https://textatruck.acidni.net/signup" class="hover:text-white transition-colors">Sign Up</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
          <p>&copy; {new Date().getFullYear()} Acidni LLC. All rights reserved.</p>
          <p class="text-gray-600">Text-a-Truck v{new Date().getFullYear().toString().slice(2)}{String(new Date().getMonth()+1).padStart(2,'0')}{String(new Date().getDate()).padStart(2,'0')}-{String(new Date().getUTCHours()).padStart(2,'0')}{String(new Date().getUTCMinutes()).padStart(2,'0')}</p>
        </div>
      </div>
    </footer>
  </body>
</html>
